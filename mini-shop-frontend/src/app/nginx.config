server {
    listen 80;
    server_name localhost;

    location / {
        root   /usr/share/nginx/html;
        index  index.html index.htm;
        
        # 🔥 အသက်သွေးကြောလိုင်း - /admin သို့မဟုတ် /profile ကို Refresh နှိပ်ရင် 
        # 404 မပြဘဲ index.html ဆီ ပြန်ပို့ပေးပြီး Angular Router ကို အလုပ်လုပ်ခိုင်းမယ့် Logic
        try_files $uri $uri/ /index.html;
    }

    # Backend API သို့ လှမ်းပို့မည့် Reverse Proxy (လိုပြောင်းနိုင်ရန်)
    location /api/ {
        proxy_pass http://backend-container:8080/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}